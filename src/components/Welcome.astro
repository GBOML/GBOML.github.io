---
import Button from './UI/Button.astro';
import links from '../list/shared-links.json';
import logo from '../assets/gboml.png';
import { Image } from 'astro:assets';
---

<section id="home">
    <div class="text-container">
        <h1>GBOML</h1>
        <h3>Official website</h3>
    
        <h2>Graph-Based Optimization Modeling Language</h2>
        <p>A specialized language for modeling discrete-time optimization problems with a clear graph-based structure, designed for researchers and engineers.</p>

        <div class="button-group">
            <Button 
                href={links.documentation.url} 
                title={links.documentation.label} 
                icon={links.documentation.icon}
                label={links.documentation.label}
                color="var(--dark-mode-primary-color)"
            />
            <Button 
                href={links.github.url}
                title={links.github.label}
                icon={links.github.icon}
                label={links.github.label}
            />
        </div>
    </div>
    
    <div>
        <Image src={logo} alt="GBOML Logo" class="logo"/>
    </div>
</section>

<style>
    section {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        gap: 50px;
    }

    section > div {
        height: 60vh;
    }

    .logo {
        width: 550px;
        height: 550px;
        box-shadow: 0 0 10px var(--border-color);
        border-radius: 100%;
    }

    .text-container {
        width: 50%;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .header-container {
        display: flex;
        flex-direction: column;
        align-items: baseline;
    }

    h1 {
        font-size: 4rem;
        margin-bottom: 0;
    }

    h2 {
        color: var(--primary-color);
        font-size: 2rem;
        font-weight: lighter;
    }

    h3 {
        font-size: 0.8rem;
        font-weight: normal;
        font-style: italic;
        color: var(--text-color-secondary);
        margin: 0;
    }

    p {
        margin: 50px 0;
        font-size: 1.3rem;
        line-height: 1.5;
    }

    .button-group {
        display: flex;
        gap: 20px;
    }

    @media (max-width: 1024px) {
        section {
            flex-direction: column-reverse;
            justify-content: center;
            gap: 0;
            padding-top: 100px;
            min-height: 100vh;
        }

        section > div {
            height: auto;
        }

        .logo {
            width: 35vh;
            height: 35vh;
            margin: 0 auto;
        }

        .text-container {
            width: 100%;
            text-align: center;
        }

        h1 {
            margin-top: 10px;
            font-size: 2.5rem;
        }

        h2 {
            font-size: 1.3rem;
        }

        h3 {
            margin-bottom: 10px;
        }

        p {
            font-size: 1rem;
        }

        h2,
        p {
            margin: 0 0 10px 0;
        }

        .button-group {
            justify-content: center;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }
    }
</style>