---
import Card from './Card.astro';

interface Props {
    items: {
        title: string;
        authors: string;
        publication?: string;
        date?: string;
        'article-link'?: string;
        'code-link'?: string;
    }[];
}

const { items } = Astro.props;
---

<div class="papers-list">
    {items.map(paper => (
        <Card
            label={paper.publication ?? 'Under review'}
            title={paper.title}
            authors={paper.authors}
            date={paper.date}
            link={paper['article-link']}
            codeUrl={paper['code-link']}
        />
    ))}
</div>

<style>
    .papers-list {
        border: 1px solid rgba(152, 206, 237, 0.2);
        border-radius: 12px;
        overflow: hidden;
        background-color: rgba(24, 28, 33, 0.5);
    }
</style>