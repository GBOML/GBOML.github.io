---
const citation = 
`
@article{Miftari2023,
    author = {Bardhyl Miftari, Mathias Berger, Guillaume Derval, Quentin Louveaux and Damien Ernst},
    title = {GBOML: a structure-exploiting optimization modelling language in Python},
    journal = {Optimization Methods and Software},
    volume = {0},
    number = {0},
    pages = {1-30},
    year = {2023},
    publisher = {Taylor & Francis},
    doi = {10.1080/10556788.2023.2246169},
    URL = {https://doi.org/10.1080/10556788.2023.2246169},
    eprint = {https://doi.org/10.1080/10556788.2023.2246169}
}`;

const formattedCitation = citation
    .replace(
        /(\s+)(\w+)(\s*=)/g,
        '$1<span style="color: var(--primary-color); font-family: var(--font-family-secondary);">$2</span>$3'
    );

const formattedCitationBis = formattedCitation
    .replace(
        /(@\w+)/g,
        '<span style="color: var(--primary-color); font-family: var(--font-family-secondary);">$1</span>'
    );
---

<script>
    function copyCitation() {
        const citationElement = document.getElementById('citation');
        if (!citationElement) return;
        navigator.clipboard.writeText(citationElement.textContent).then(() => {
            const toast = document.getElementById('toast');
            if (!toast) return;
            toast.classList.add('show');
            setTimeout(() => {
                toast.classList.remove('show');
            }, 2000);
        });
    }

    document.addEventListener('DOMContentLoaded', () => {
        const button = document.querySelector('button[data-copy]');
        if (button) {
            button.addEventListener('click', copyCitation);
        }
    });
</script>

<section>
    <div class="header">
        <h2>Citing GBOML</h2>
    </div>

    <div class="container">
        <div class="content">
            <pre id="citation" set:html={formattedCitationBis}></pre>
             
            <button data-copy title="Copy citation">
                <i class="fa-regular fa-copy fa-lg"></i>
            </button>
        </div>
        <div id="toast" class="toast">Copied to clipboard!</div>
    </div>
</section>

<style>
    section {
        background-color: var(--secondary-color);
        position: relative;
    }

    .container {
        width: 100%;     
        display: flex;
        justify-content: center;   
        margin-top: 40px;
    }
    
    .content {
        background-color: var(--background-color);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        display: flex;
    }

    .container:hover pre {
        transform: translateX(2px);
    }
    
    pre {
        font-family: var(--font-family-secondary);
        letter-spacing: 0.5px;
        font-size: 0.9rem;
        line-height: 1.3;
        margin: 0;
        padding: 20px 24px;
        transition: all 0.2s ease-in-out;
    }

    h2 {
        font-size: 2.5rem;
        margin: 0;
        color: var(--text-color);
    }

    button {
        border: none;
        background: none;
        cursor: pointer;
        transition: transform 0.2s ease-in-out;
        color: var(--text-color-secondary);
        align-self: start;
        padding: 15px 16px;
    }

    button:hover {
        transform: scale(1.1);
    }

    button:active {
        transform: scale(0.95);
    }

    .toast {
        position: absolute;
        bottom: 20px;
        right: 20px;
        background-color: var(--primary-color);
        color: white;
        padding: 12px 20px;
        border-radius: 8px;
        font-size: 0.8rem;
        opacity: 0;
        transition: opacity 0.3s ease-in-out;
        pointer-events: none;
    }

    .toast.show {
        opacity: 1;
    }

    @media (max-width: 1024px) {
        .container {
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }

        .content {
            width: 100%;
        }

        pre {
            overflow-x: auto;
            font-size: 0.8rem;
            padding: 16px 20px;
        }
    }
</style>