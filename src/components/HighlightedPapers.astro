---
import Card from './Card.astro';
import ViewAllButton from './ViewAllButton.astro';
import papers from '../list/use-gboml-papers.json';

const topPapers = [
    papers.find((paper) => paper.id == "9")!,
    papers.find((paper) => paper.id == "10")!,
    papers.find((paper) => paper.id == "1")!
];
---

<section id="publications">
    <div class="papers-header">
        <div>
            <p class="section-label">RESEARCH HIGHLIGHTS</p>
            <h2>Papers using GBOML</h2>
        </div>
         <ViewAllButton sectionId="smart-grids-papers" />
    </div>

    <div class="papers-grid">
        {topPapers.map(paper => (
            <Card
                image={`./articles-img/${paper.image}`}
                label={paper.publication ? paper.publication.split(',')[0] : 'Under review'}
                title={paper.title}
                authors={paper.authors}
                date={paper.date}
                link={paper['article-link']}
                codeUrl={paper['code-link']}
            />
        ))}
    </div>
</section>

<style>
    .papers-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 60px 0 40px 0;
        gap: 40px;
    }

    .section-label {
        color: var(--primary-color);
        font-family: var(--font-family-secondary);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 0 0 16px 0;
    }

    h2 {
        font-size: 3rem;
        margin: 0;
        color: var(--text-color);
    }

    .papers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 32px;
    }

    @media (max-width: 1200px) {
        .papers-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 1024px) {
        .papers-header {
            flex-direction: column;
            gap: 20px;
            margin-bottom: 40px;
            text-align: center;
        }

        h2 {
            font-size: 2rem;
        }

        .papers-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
